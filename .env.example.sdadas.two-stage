# Shared storage/backend settings
CODE_DIRECTORY=/code
VECTOR_DB_BACKEND=lancedb
LANCEDB_PATH="./lancedb_data"
QDRANT_URL=http://vdb:6333
HF_TOKEN=hf_TOKEN
HF_DATASET="minehard/negatives"
DATABASE_COLLECTION_NAME="natural_questions_documents"

# Retrieval/indexing
SPLADE_MODEL_NAME="sdadas/polish-splade"
DENSE_EMBEDDER_NAME="sdadas/mmlw-retrieval-roberta-base"
DENSE_PROMPT="zapytanie: "
EMBEDDER_BATCH_SIZE=16
DENSE_EMBEDDER_MAX_LENGTH=512
SPARSE_EMBEDDER_MAX_LENGTH=512
LANCEDB_DB_WRITE_BATCH_SIZE=4096
ADD_DOCUMENTS_RESUME=true
LANCEDB_ASYNC_WRITE=true
ADD_DOCUMENTS_AUTO_BATCH_SIZE_MIN=16
ADD_DOCUMENTS_AUTO_BATCH_SIZE_MAX=128
ADD_DOCUMENTS_AUTO_BATCH_SIZE_SAMPLE_SIZE=512

# Two-stage reranking model names
CANDIDATE_RERANKER_NAME="sdadas/polish-reranker-base-ranknet"
CANDIDATE_RERANKER_BATCH_SIZE=16
FINAL_RERANKER_NAME="sdadas/polish-reranker-roberta-v3"
FINAL_RERANKER_BATCH_SIZE=4

# Default RERANKER_NAME is the small candidate reranker.
RERANKER_NAME="sdadas/polish-reranker-base-ranknet"
RERANKER_BATCH_SIZE=16
RERANKER_MAX_LENGTH=512

# Natural Questions conversion
NATURAL_QUESTIONS_DATASET="speakleash/natural-questions-pl"
NATURAL_QUESTIONS_SPLIT="train"
NATURAL_QUESTIONS_BATCH_SIZE=10000
MSMARCO_EXTRA_DOCS=1500000
NQ_DOC_ID_START=10000000
NATURAL_QUESTIONS_SEED=42
SKIP_USED_CORPUS_FILTER=false
USED_CORPUS_DATASET="minehard/negatives2"

# Standard pipeline paths
INPUT_FILE_PATH="data/input.jsonl"
QUERIES_PATH="data/queries.parquet"
CORPUS_PATH="data/corpus.parquet"
RELEVANT_PATH="data/relevant.parquet"
RELEVANT_WITH_SCORE_PATH="data/relevant_with_score.parquet"
NEGATIVES_PATH="data/negatives.parquet"
OUTPUT_PATH="data/output.jsonl"

# Two-stage intermediate paths
RELEVANT_WITH_CANDIDATE_SCORE_PATH="data/relevant_with_candidate_score.parquet"
NEGATIVE_CANDIDATES_PATH="data/negative_candidates.parquet"

# add_positives_ranks.py stage defaults.
# First pass: python app_code/add_positives_ranks.py
CANDIDATE_POSITIVE_RANKS_OUTPUT_PATH="data/relevant_with_candidate_score.parquet"
CANDIDATE_POSITIVE_RANKS_RERANKER_NAME="sdadas/polish-reranker-base-ranknet"
CANDIDATE_POSITIVE_RANKS_RERANKER_BATCH_SIZE=16
CANDIDATE_POSITIVE_RANKS_SCORE_COLUMN="positive_candidate_ranking"

# Final pass: python app_code/add_positives_ranks.py --final-step
FINAL_POSITIVE_RANKS_OUTPUT_PATH="data/relevant_with_score.parquet"
FINAL_POSITIVE_RANKS_RERANKER_NAME="sdadas/polish-reranker-roberta-v3"
FINAL_POSITIVE_RANKS_RERANKER_BATCH_SIZE=4
FINAL_POSITIVE_RANKS_SCORE_COLUMN="positive_ranking"

# Score column names for the optional two-stage flow
CANDIDATE_POSITIVE_SCORE_COLUMN="positive_candidate_ranking"
FINAL_POSITIVE_SCORE_COLUMN="positive_ranking"
NEGATIVE_RANKING_COLUMN="candidate_ranking"
NEGATIVE_POSITIVE_SCORE_COLUMN="positive_candidate_ranking"
FINAL_RANKING_COLUMN="final_ranking"
POSITIVE_SCORE_COLUMN="positive_ranking"
NEGATIVE_SCORE_COLUMN="final_ranking"

# Mining/export sizes
TOP_K=500
NUM_NEGATIVES=10
NEGATIVES_THRESHOLD=0.2
PROCESSING_CHUNK_SIZE=4096
NEGATIVES_PARQUET_ROW_GROUP_SIZE=100000
NEGATIVE_QUERY_BATCH_SIZE=4
BETA=0.01
U_FLOOR=0.005
QUERY_CHUNK_SIZE=1000
OVERSAMPLE_FACTOR=5
CORPUS_SQLITE_PATH="data/corpus.sqlite"
NEGCOUNT_SQLITE_PATH="data/negcount.sqlite"

# Legacy threshold knobs kept for compatibility with older commands
NEGATIVES_MULTIPLICATION_THRESHOLD=
NEGATIVES_SUBTRACTION_THRESHOLD=5.0
