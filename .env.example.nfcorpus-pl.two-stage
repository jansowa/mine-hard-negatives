# Shared storage/backend settings
CODE_DIRECTORY=/code
VECTOR_DB_BACKEND=lancedb
LANCEDB_PATH="./lancedb_data"
QDRANT_URL=http://vdb:6333
HF_TOKEN=
HF_DATASET="minehard/nfcorpus-pl-negatives"
DATABASE_COLLECTION_NAME="nfcorpus_pl_documents"

# Retrieval/indexing
SPLADE_MODEL_NAME="sdadas/polish-splade"
DENSE_EMBEDDER_NAME="sdadas/mmlw-retrieval-roberta-base"
DENSE_PROMPT="zapytanie: "
EMBEDDER_BATCH_SIZE=16
DENSE_EMBEDDER_MAX_LENGTH=512
SPARSE_EMBEDDER_MAX_LENGTH=512
LANCEDB_DB_WRITE_BATCH_SIZE=4096
ADD_DOCUMENTS_RESUME=true
LANCEDB_ASYNC_WRITE=true
ADD_DOCUMENTS_AUTO_BATCH_SIZE_MIN=16
ADD_DOCUMENTS_AUTO_BATCH_SIZE_MAX=128
ADD_DOCUMENTS_AUTO_BATCH_SIZE_SAMPLE_SIZE=512

# Two-stage reranking model names
CANDIDATE_RERANKER_NAME="sdadas/polish-reranker-base-ranknet"
CANDIDATE_RERANKER_BATCH_SIZE=16
FINAL_RERANKER_NAME="sdadas/polish-reranker-roberta-v3"
FINAL_RERANKER_BATCH_SIZE=4
RERANKER_NAME="sdadas/polish-reranker-base-ranknet"
RERANKER_BATCH_SIZE=16
RERANKER_MAX_LENGTH=512

# nfcorpus-pl conversion
NFCORPUS_DATASET="clarin-knext/nfcorpus-pl"
NFCORPUS_QRELS_DATASET="clarin-knext/nfcorpus-pl-qrels"
NFCORPUS_QRELS_SPLITS="train,validation,test"
NFCORPUS_CORPUS_TEXT_MODE="title_text"
NFCORPUS_MIN_QREL_SCORE=1
NFCORPUS_BATCH_SIZE=10000

# Standard pipeline paths
QUERIES_PATH="data/nfcorpus_pl/queries.parquet"
CORPUS_PATH="data/nfcorpus_pl/corpus.parquet"
RELEVANT_PATH="data/nfcorpus_pl/relevant.parquet"
RELEVANT_WITH_SCORE_PATH="data/nfcorpus_pl/relevant_with_score.parquet"
NEGATIVES_PATH="data/nfcorpus_pl/negatives.parquet"
OUTPUT_PATH="data/nfcorpus_pl/train.jsonl"

# Two-stage intermediate paths
RELEVANT_WITH_CANDIDATE_SCORE_PATH="data/nfcorpus_pl/relevant_with_candidate_score.parquet"
NEGATIVE_CANDIDATES_PATH="data/nfcorpus_pl/negative_candidates.parquet"

# add_positives_ranks.py stage defaults.
CANDIDATE_POSITIVE_RANKS_OUTPUT_PATH="data/nfcorpus_pl/relevant_with_candidate_score.parquet"
CANDIDATE_POSITIVE_RANKS_SCORE_COLUMN="positive_candidate_ranking"
FINAL_POSITIVE_RANKS_OUTPUT_PATH="data/nfcorpus_pl/relevant_with_score.parquet"
FINAL_POSITIVE_RANKS_SCORE_COLUMN="positive_ranking"

# Score column names for the optional two-stage flow
CANDIDATE_POSITIVE_SCORE_COLUMN="positive_candidate_ranking"
FINAL_POSITIVE_SCORE_COLUMN="positive_ranking"
NEGATIVE_RANKING_COLUMN="candidate_ranking"
NEGATIVE_POSITIVE_SCORE_COLUMN="positive_candidate_ranking"
FINAL_RANKING_COLUMN="final_ranking"
POSITIVE_SCORE_COLUMN="positive_ranking"
NEGATIVE_SCORE_COLUMN="final_ranking"

# Mining/export sizes
TOP_K=500
NUM_NEGATIVES=10
NEGATIVES_THRESHOLD=0.2
PROCESSING_CHUNK_SIZE=4096
NEGATIVES_PARQUET_ROW_GROUP_SIZE=100000
NEGATIVE_QUERY_BATCH_SIZE=4
BETA=0.01
U_FLOOR=0.005
CANDIDATE_BETA=0.01
CANDIDATE_U_FLOOR=0.005
CANDIDATE_TARGET=40
CANDIDATE_SEARCH_CHUNK=128
CANDIDATE_MAX_OFFSET_ITERS=10
CANDIDATE_RANDOM_FALLBACK=128
FINAL_BETA=0.01
FINAL_U_FLOOR=0.005
FINAL_RERANK_MODE=adaptive
FINAL_RERANK_INITIAL_BUDGET=20
FINAL_RERANK_BUDGET_STEP=10
FINAL_RERANK_MAX_BUDGET=80
BACKFILL_POLICY=relaxed
QUERY_CHUNK_SIZE=1000
OVERSAMPLE_FACTOR=5
CORPUS_SQLITE_PATH="data/nfcorpus_pl/corpus.sqlite"
NEGCOUNT_SQLITE_PATH="data/nfcorpus_pl/negcount.sqlite"
FINAL_RERANK_REPORT_PATH="data/nfcorpus_pl/negatives.parquet.report.json"
EXPORT_REPORT_PATH="data/nfcorpus_pl/train.jsonl.report.json"

# Optional synthetic-positive mining from already final-scored candidates.
MINE_POSITIVES=false
MAX_MINED_POSITIVES=1
U_SANITY_CEILING=0.90
U_ABSOLUTE_CEILING=0.995
U_POSITIVE_BETA=0.95
POSITIVE_NEAR_DUPLICATE_THRESHOLD=0.80

# Legacy threshold knobs kept for compatibility with older commands
NEGATIVES_MULTIPLICATION_THRESHOLD=
NEGATIVES_SUBTRACTION_THRESHOLD=5.0
