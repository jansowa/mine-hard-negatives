# LightOn adaptive compact pipeline with mixedbread-ai/mxbai-rerank-base-v2.
#
# Usage:
#   cp .env.example.lightonai.mxbai .env
#   # edit LIGHTONAI_SPLITS if needed
#   python app_code/curated_negatives/run_lightonai_adaptive_pipeline.py

# One reranker is used for both positives and candidate negatives so percentile
# thresholds are computed in the same score space.
RERANKER_NAME="mixedbread-ai/mxbai-rerank-base-v2"
CANDIDATE_RERANKER_NAME="mixedbread-ai/mxbai-rerank-base-v2"
FINAL_RERANKER_NAME="mixedbread-ai/mxbai-rerank-base-v2"
RERANKER_MAX_LENGTH=512

# LightOn input and per-split output folders.
LIGHTONAI_DATASET_NAME="lightonai/embeddings-fine-tuning"
# You can use following splits: "trivia", "hotpotqa", "nq", "msmarco", "fever", "squadv2", "fiqa"
LIGHTONAI_SPLITS="fiqa,trivia,fever"
LIGHTONAI_PIPELINE_ROOT="data/lightonai_pipeline"
LIGHTONAI_STAGES="artifacts,positives,negatives,jsonl"

# Final dataset shape and threshold policy.
NUM_NEGATIVES=10
BETA=0.01
U_FLOOR=0.005
FINAL_BETA=0.01
FINAL_U_FLOOR=0.005
FINAL_RERANK_MODE=adaptive
FINAL_RERANK_INITIAL_BUDGET=20
FINAL_RERANK_BUDGET_STEP=10
# 0 means no fixed cap: inspect more LightOn candidates until NUM_NEGATIVES
# strict negatives are found or the query's candidate list is exhausted.
FINAL_RERANK_MAX_BUDGET=0
BACKFILL_POLICY=relaxed

# Score column names used by the compact LightOn pipeline.
FINAL_POSITIVE_RANKS_SCORE_COLUMN="positive_ranking"
FINAL_POSITIVE_SCORE_COLUMN="positive_ranking"
POSITIVE_SCORE_COLUMN="positive_ranking"
NEGATIVE_RANKING_COLUMN="candidate_ranking"
FINAL_RANKING_COLUMN="final_ranking"
NEGATIVE_SCORE_COLUMN="final_ranking"
POSITIVE_ORIGINAL_SCORE_COLUMN="lightonai_positive_score"
NEGATIVE_ORIGINAL_SCORE_COLUMN="candidate_ranking"
FLAG_EMBEDDING_PROMPT=""
FLAG_EMBEDDING_TYPE="retrieval"

# Throughput and resume defaults. Leave FINAL_RERANKER_BATCH_SIZE unset to
# let the startup benchmark pick a safe batch size for the current GPU.
PROCESSING_CHUNK_SIZE=4096
QUERY_CHUNK_SIZE=1000
OVERSAMPLE_FACTOR=5
MAX_NEG_REUSE=1000
NEGATIVES_PARQUET_ROW_GROUP_SIZE=100000
FINAL_RERANK_RESUME=true
FINAL_POSITIVE_RANKS_AUTO_RERANKER_BATCH_SIZE_MIN=1
FINAL_POSITIVE_RANKS_AUTO_RERANKER_BATCH_SIZE_MAX=64
FINAL_POSITIVE_RANKS_AUTO_RERANKER_BATCH_SIZE_SAMPLE_SIZE=128
FINAL_AUTO_RERANKER_BATCH_SIZE_MIN=1
FINAL_AUTO_RERANKER_BATCH_SIZE_MAX=64
FINAL_AUTO_RERANKER_BATCH_SIZE_SAMPLE_SIZE=128
